      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf C:*)",
      "Bash(rm -rf D:*)",
      "Bash(format *)",
      "Bash(mkfs *)",
      "Bash(dd if=* of=/dev/*)",
      "Bash(chmod 777 *)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push -f origin main*)",
      "Bash(git push -f origin master*)",
      "Bash(git push --force origin main*)",
      "Bash(git push --force origin master*)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push --force-with-lease origin master*)",
      "Bash(npm publish)",
      "Bash(npm publish *)",
      "Bash(pip install --break-system-packages *)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl drain *)",
      "Bash(terraform destroy)",
      "Bash(terraform destroy *)",
      "Bash(aws s3 rb *)",
      "Bash(aws ec2 terminate-instances *)",
      "Bash(redis-cli FLUSHALL)",
      "Bash(redis-cli FLUSHDB)",
      "Bash(DROP DATABASE *)",
      "Bash(DROP TABLE *)",
      "Read(.env.production)",
      "Read(.env.prod)",
      "Read(.env.staging)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)"
    ],
    "defaultMode": "bypassPermissions"
  },
