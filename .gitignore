*.lock

# Plugin runtime (caches, sweeps, downloaded marketplaces — regenerable)
plugins/cache/
plugins/marketplaces/
plugins/.last_inuse_sweep
plugins/*/config-cache/
plugins/*/context-cache/
plugins/*/transcript-cache/

# History, Logs & Backups (root-runtime, anchored)
/logs/
/history/
/file-history/
/backups/
/telemetry/
/shell-snapshots/
/daily_summary/
history.jsonl
*.log

