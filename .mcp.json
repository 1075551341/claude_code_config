{
  "$schema": "https://github.com/modelcontextprotocol/spec/blob/main/schema/schema.json",
  "_comment": "MCP 服务器配置 | 精简版：仅保留可用服务，避免进程泄漏导致 Cursor 无法关闭",
  "mcpServers": {
    "redis": {
      "_description": "Redis 缓存/队列/键值存储。场景：缓存热点数据、会话存储、消息队列、分布式锁",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://localhost:6379"
      ]
    },
    "fs": {
      "_description": "文件系统操作。场景：读写项目文件、管理配置、批量重命名",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\apdms",
        "C:\\Users\\DELL\\.claude"
      ]
    },
    "fetch": {
      "_description": "HTTP 请求工具。场景：获取网页内容、调用 REST API、下载远程资源",
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {}
    },
    "git": {
      "_description": "Git 版本库直接操作。场景：查看提交历史、diff、blame、本地分支操作",
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "D:\\apdms"]
    },
    "memory": {
      "_description": "跨会话记忆持久化。场景：记住项目架构决策、用户偏好、重要上下文",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "thinking": {
      "_description": "结构化逐步推理。场景：复杂架构设计、多方案比较、调试链路分析",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "time": {
      "_description": "时间与时区工具。场景：获取当前时间、时区转换、计算时间差",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"]
    },
    "sqlite": {
      "_description": "SQLite 轻量数据库。场景：本地原型开发、小型数据存储、测试数据库",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "D:\\apdms\\database.db"
      ]
    },
    "ctx7": {
      "_description": "Context7 技术文档查询。场景：查 React/Vue/Express/Node 等库的最新 API",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "crawl": {
      "_description": "Firecrawl 网页爬取。场景：提取网页正文内容、批量采集数据、抓取文档",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "gh": {
      "_description": "GitHub API 集成。场景：管理 PR/Issue、查看 Actions 状态、搜索仓库",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "pw": {
      "_description": "Playwright 浏览器自动化。场景：E2E 测试、网页截图、表单填写",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
