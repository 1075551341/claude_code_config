{
  "$schema": "https://modelcontextprotocol.io/schema/2024-11-05/servers",
  "_comment": "MCP 分组视图 v4.0 | 权威源: .mcp.json | 仅定义toolset分组映射",
  "toolsets": {
    "always": ["memory", "thinking", "fs", "fetch", "time"],
    "dev": ["gh", "git", "ctx7", "pw", "crawl", "chrome-devtools"],
    "ops": ["redis", "sqlite", "docker", "postgres"],
    "search": ["brave", "exa"],
    "design": ["figma"],
    "optional": ["claude-context", "puppeteer", "glif"]
  },
  "loading": {
    "default": "always",
    "env": "CLAUDE_MCP_PROFILE",
    "profiles": {
      "dev": "always + dev",
      "ops": "always + ops",
      "search": "always + search",
      "design": "always + design",
      "full": "always + dev + ops + search + design"
    }
  }
}
