{
  "$schema": "https://modelcontextprotocol.io/schema/2024-11-05/servers",
  "_comment": "MCP 分组视图 v4.0 | 权威源: .mcp.json | 仅定义toolset分组映射",
  "toolsets": {
    "always": [
      "fs",
      "time"
    ],
    "dev": [
      "git",
      "crawl",
      "chrome-devtools",
      "codegraph"
    ],
    "ops": [
      "redis",
      "sqlite",
      "docker",
      "postgres"
    ],
    "design": [
      "figma"
    ],
    "optional": []
  },
  "loading": {
    "default": "always",
    "env": "CLAUDE_MCP_PROFILE",
    "profiles": {
      "dev": "always + dev",
      "ops": "always + ops",
      "design": "always + design",
      "full": "always + dev + ops + design"
    }
  }
}
